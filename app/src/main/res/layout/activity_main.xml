<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#0D0D14"
    android:theme="@style/Theme.AirPodsSignal">

    <!-- 标题 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎧"
            android:textSize="32sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  模拟信号"
            android:textSize="26sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BLE AirPods Pro 广播器"
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginTop="4dp" />

    <!-- 脉冲动画指示 -->
    <FrameLayout
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginTop="40dp"
        android:layout_gravity="center">

        <View
            android:id="@+id/pulse_3"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center"
            android:background="@drawable/pulse_circle" />

        <View
            android:id="@+id/pulse_2"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_gravity="center"
            android:background="@drawable/pulse_circle" />

        <View
            android:id="@+id/pulse_1"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:background="@drawable/pulse_circle" />

        <View
            android:id="@+id/dot_center"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_gravity="center"
            android:background="@drawable/dot_center" />
    </FrameLayout>

    <!-- 状态 -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/txt_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="就绪"
        android:textSize="14sp"
        android:textColor="#888888"
        android:layout_marginTop="20dp" />

    <!-- 广播包结构 -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/txt_packet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="11sp"
        android:typeface="monospace"
        android:textColor="#555555"
        android:lineSpacingExtra="4dp"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:padding="16dp"
        app:shapeAppearanceOverlay="@style/RoundedCorner"
        android:background="#1A1A24" />

    <Space
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- 按钮 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_toggle"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="开始广播"
        android:textSize="16sp"
        android:enabled="false"
        android:layout_marginBottom="24dp"
        app:cornerRadius="14dp" />

</LinearLayout>
